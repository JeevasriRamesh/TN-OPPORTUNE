# auth.http
# Manual tests for backend authentication APIs.
# Requires the REST Client extension (e.g., in VS Code).
# To run: open this file, click "Send Request" above each request.

### Register user
POST http://localhost:3001/api/auth/register
Content-Type: application/json

{
  "username": "testuser1",
  "email": "test1@gmail.com",
  "password": "123456"
}

###

### Login user
POST http://localhost:3001/api/auth/login
Content-Type: application/json

{
  "email": "test1@gmail.com",
  "password": "123456"
}

